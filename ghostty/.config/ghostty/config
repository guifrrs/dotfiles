# Shell
# Unset ZDOTDIR to work around Ghostty bug that sets it even with shell-integration = none
command = /usr/bin/env -u ZDOTDIR /bin/zsh -l
shell-integration = none

# Appearance
font-family = NotoSansM Nerd Font Mono
font-size = 15
theme = Catppuccin Frappe
window-padding-x = 4
window-padding-y = 4
cursor-style = bar

# Splits
keybind = ctrl+d=new_split:right
keybind = shift+ctrl+d=new_split:down
keybind = ctrl+h=goto_split:left
keybind = ctrl+l=goto_split:right
keybind = ctrl+k=goto_split:top
keybind = ctrl+j=goto_split:bottom
